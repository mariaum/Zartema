                 return false;
             }
+            // Zartema start
+            if (!listener.isProxyProtocol()) {
+                if ( BungeeCord.getInstance().getPluginManager().callEvent( new com.mariaum.zartema.event.ClientAddressAvailableEvent( remoteAddress ) ).isCancelled() )
