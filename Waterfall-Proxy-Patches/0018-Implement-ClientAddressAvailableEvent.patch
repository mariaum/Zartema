Subject: [PATCH] Implement ClientAddressAvailableEvent.


diff --git a/api/src/main/java/com/mariaum/zartema/event/ClientAddressAvailableEvent.java b/api/src/main/java/com/mariaum/zartema/event/ClientAddressAvailableEvent.java
new file mode 100644
index 00000000..d628d040
--- /dev/null
+++ b/api/src/main/java/com/mariaum/zartema/event/ClientAddressAvailableEvent.java
@@ -0,0 +1,18 @@
+package com.mariaum.zartema.event;
+
+import lombok.Data;
+import lombok.EqualsAndHashCode;
+import lombok.ToString;
+import net.md_5.bungee.api.plugin.Cancellable;
+import net.md_5.bungee.api.plugin.Event;
+
+import java.net.SocketAddress;
+
+@Data
+@ToString(callSuper = false)
+@EqualsAndHashCode(callSuper = false)
+public class ClientAddressAvailableEvent extends Event implements Cancellable
+{
+    private boolean cancelled;
+    private final SocketAddress socketAddress;
+}
diff --git a/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java b/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
index c336f1b3..969c2db4 100644
--- a/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
+++ b/proxy/src/main/java/net/md_5/bungee/netty/HandlerBoss.java
@@ -12,6 +12,7 @@ import java.io.IOException;
 import java.net.InetSocketAddress;
 import java.util.logging.Level;
 import lombok.Setter;
+import net.md_5.bungee.BungeeCord;
 import net.md_5.bungee.api.ProxyServer;
 import net.md_5.bungee.api.chat.TextComponent;
 import net.md_5.bungee.connection.CancelSendSignal;
@@ -103,6 +104,14 @@ public class HandlerBoss extends ChannelInboundHandlerAdapter
                     } );
 
                     channel.setRemoteAddress( newAddress );
+
+                    // Zartema start
+                    if ( BungeeCord.getInstance().getPluginManager().callEvent( new com.mariaum.zartema.event.ClientAddressAvailableEvent( newAddress )).isCancelled() )
+                    {
+                        this.channel.close();
+                        return;
+                    }
+                    // Zartema end
                 } else
                 {
                     healthCheck = true;
